[
  {
    "collection": "users",
    "description": "User accounts and profiles",
    "fields": [
      { "name": "uid", "type": "string", "description": "Firebase Auth user ID" },
      { "name": "email", "type": "string", "description": "User's email" },
      { "name": "displayName", "type": "string", "description": "User's display name" },
      { "name": "photoURL", "type": "string", "description": "Profile picture URL" },
      { "name": "theme", "type": "string", "description": "User's UI theme preference (dark/light)" },
      { "name": "createdAt", "type": "timestamp", "description": "Timestamp of account creation" }
    ]
  },
  {
    "collection": "chats",
    "description": "Chat conversations between user and AI models",
    "fields": [
      { "name": "userId", "type": "string", "description": "ID of the user who owns this chat" },
      { "name": "title", "type": "string", "description": "Title of the chat" },
      { "name": "model", "type": "string", "description": "The AI model used for the chat" },
      { "name": "sessionId", "type": "string", "description": "Session identifier for stateful models like ai-coder" },
      { "name": "messages", "type": "array", "description": "Array of message objects" },
      { "name": "createdAt", "type": "timestamp", "description": "When the chat was created" },
      { "name": "updatedAt", "type": "timestamp", "description": "When the chat was last updated" }
    ]
  },
  {
    "collection": "imagePrompts",
    "description": "History of generated image prompts",
    "fields": [
      { "name": "userId", "type": "string", "description": "ID of the user who owns this prompt" },
      { "name": "inputQuery", "type": "string", "description": "The user's original query text" },
      { "name": "generatedPrompt", "type": "string", "description": "The enhanced prompt generated by AI" },
      { "name": "createdAt", "type": "timestamp", "description": "When the prompt was generated" }
    ]
  }
]
